{
  "name": "mailarchive",
  "private": true,
  "workspaces": [
    "api",
    "worker",
    "web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w api",
    "dev:worker": "npm run dev -w worker",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w api && npm run build -w worker && npm run build -w web",
    "db:migrate": "npm run db:migrate -w api",
    "db:migrate:create": "npm run db:migrate:create -w api"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "googleapis": "^170.1.0"
  }
}
