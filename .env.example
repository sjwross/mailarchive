# PostgreSQL connection string
# For hosting that requires SSL (e.g. A2 Hosting), add ?sslmode=require:
# DATABASE_URL=postgres://user:password@host:5432/mailarchive?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/mailarchive

# JWT signing secret (use a strong value in production)
JWT_SECRET=your-secret-here

# Redis URL for BullMQ (worker)
REDIS_URL=redis://localhost:6379

# Optional: API port (default 3000)
# PORT=3000

# For cron: secret sent in X-Cron-Secret when calling POST /api/jobs/run-scheduled
# CRON_SECRET=your-strong-cron-secret

# ntfy (optional): phone/desktop push for manual Run Now and (via cron env) scheduled runs
# NTFY_TOPIC=your-private-topic
# NTFY_URL=https://ntfy.sh
# NTFY_TOKEN=
# NTFY_ON_SUCCESS=0

# Microsoft OAuth (Phase 2)
# Get these from https://portal.azure.com -> Azure Active Directory -> App registrations
# Example values (replace with your actual values from Azure App Registration):
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000001
MICROSOFT_CLIENT_SECRET=your-client-secret-here
# Use your Directory (tenant) ID or "common" for multi-tenant
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000002
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/microsoft/callback

# Encryption key for storing tokens (use a strong random value in production)
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Google Drive (optional, Phase 3+)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gdrive/callback
