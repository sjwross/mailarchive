# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/mailarchive

# JWT signing secret (use a strong value in production)
JWT_SECRET=your-secret-here

# Redis URL for BullMQ (worker)
REDIS_URL=redis://localhost:6379

# Optional: API port (default 3000)
# PORT=3000

# Microsoft OAuth (Phase 2)
# Get these from https://portal.azure.com -> Azure Active Directory -> App registrations
# Example values (replace with your actual values):
MICROSOFT_CLIENT_ID=4c24c661-e708-4e8b-94da-205b48d82494
MICROSOFT_CLIENT_SECRET=your-client-secret-here
# Use your Directory (tenant) ID or "common" for multi-tenant
MICROSOFT_TENANT_ID=cc7312ca-599d-4e5f-b455-863356f48151
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/microsoft/callback

# Encryption key for storing tokens (use a strong random value in production)
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Google Drive (optional, Phase 3+)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gdrive/callback
